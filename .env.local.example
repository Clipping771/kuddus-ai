# Kuddus Ali AI - Environment Variables Template

# Clerk Authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# Supabase (PostgreSQL Database)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Groq Cloud API Key
# Obtain a free key from https://console.groq.com/
GROQ_API_KEY=gsk_...

# OpenRouter API Keys (Multi-Key Rotation System)
# Add multiple keys — when one hits the 50 req/day free limit,
# the system automatically rotates to the next key.
# Get free keys at: https://openrouter.ai/keys (create multiple accounts)
OPENROUTER_API_KEY_1=sk-or-v1-...
OPENROUTER_API_KEY_2=sk-or-v1-...
OPENROUTER_API_KEY_3=sk-or-v1-...
# Add more as needed: OPENROUTER_API_KEY_4, _5, ... up to _10

# App Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Tavily Web Search API Key (optional — enables real-time web search)
# Get a free key at: https://tavily.com
TAVILY_API_KEY=tvly-...
